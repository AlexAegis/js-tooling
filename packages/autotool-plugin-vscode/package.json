{
	"name": "@alexaegis/autotool-plugin-vscode",
	"description": "My vscode config",
	"version": "0.15.0",
	"license": "MIT",
	"private": false,
	"archetype": {
		"platform": "node",
		"framework": "autotool",
		"language": "ts",
		"kind": "lib"
	},
	"keywords": [
		"autotool-plugin",
		"managed-by-autotool",
		"vscode"
	],
	"repository": {
		"url": "git+https://github.com/AlexAegis/js-tooling",
		"type": "git"
	},
	"type": "module",
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js",
				"require": "./dist/index.cjs",
				"default": "./dist/index.js"
			},
			"./extensions": "./static/extensions.json",
			"./launch": "./static/launch.json",
			"./package.json": "./package.json",
			"./readme": "./readme.md",
			"./settings": "./static/settings.json",
			"./tasks": "./static/tasks.json"
		}
	},
	"files": [
		"dist",
		"static"
	],
	"scripts": {
		"lint:depcheck": "turbo run lint:depcheck_ --concurrency 16 --filter @alexaegis/autotool-plugin-vscode",
		"lint:depcheck_": "depcheck",
		"lint:es": "turbo run lint:es_ --concurrency 16 --filter @alexaegis/autotool-plugin-vscode",
		"lint:es_": "eslint --max-warnings=0 --fix --no-error-on-unmatched-pattern .",
		"lint:format": "turbo run lint:format_ --concurrency 16 --filter @alexaegis/autotool-plugin-vscode",
		"lint:format_": "prettier --cache-location .cache/prettier --plugin prettier-plugin-svelte --plugin prettier-plugin-tailwindcss --check .",
		"lint:md": "turbo run lint:md_ --concurrency 16 --filter @alexaegis/autotool-plugin-vscode",
		"lint:md_": "remark --frail --no-stdout --silently-ignore .",
		"lint:tsc": "turbo run lint:tsc_ --concurrency 16 --filter @alexaegis/autotool-plugin-vscode",
		"lint:tsc_": "tsc --noEmit",
		"publint": "BUILD_REASON='publish' turbo run publint_ --concurrency 16 --filter @alexaegis/autotool-plugin-vscode",
		"publint_": "publint",
		"test": "turbo run test_ --concurrency 16 --filter @alexaegis/autotool-plugin-vscode",
		"test_": "vitest --passWithNoTests --coverage --run",
		"test:watch": "vitest --passWithNoTests --coverage",
		"all": "BUILD_REASON='publish' turbo run all_ --concurrency 16 --filter @alexaegis/autotool-plugin-vscode",
		"build": "turbo run build-lib_ --concurrency 16 --filter @alexaegis/autotool-plugin-vscode",
		"build-lib_": "vite build",
		"format": "turbo run format_ --concurrency 16 --filter @alexaegis/autotool-plugin-vscode",
		"format_": "prettier --cache-location .cache/prettier --plugin prettier-plugin-svelte --plugin prettier-plugin-tailwindcss --write ."
	},
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"default": "./dist/index.js"
		},
		"./extensions": "./static/extensions.json",
		"./launch": "./static/launch.json",
		"./package.json": "./package.json",
		"./readme": "./readme.md",
		"./settings": "./static/settings.json",
		"./tasks": "./static/tasks.json"
	},
	"dependencies": {
		"@alexaegis/logging": "workspace:^",
		"autotool-plugin": "^0.6.1"
	},
	"devDependencies": {
		"@alexaegis/eslint-config-vitest": "workspace:^",
		"@alexaegis/ts": "workspace:^",
		"@alexaegis/vite": "workspace:^",
		"@alexaegis/vitest": "workspace:^",
		"@types/node": "^25.6.0",
		"publint": "^0.3.18",
		"typescript": "^6.0.3",
		"vite": "^8.0.10",
		"vite-plugin-dts": "^5.0.0",
		"vitest": "^4.1.5"
	}
}
