{
	"$schema": "https://turborepo.org/schema.json",
	"extends": ["//"],
	"tasks": {
		"build-lib_": {
			"dependsOn": [
				"@alexaegis/common#build-lib_",
				"@alexaegis/fs#build-lib_",
				"@alexaegis/workspace-tools#build-lib_",
				"@pakk/core#build-lib_",
				"@pakk/core#prebuild_"
			]
		},
		"prebuild_": {
			"env": ["TARGET_ENV"],
			"dependsOn": [
				"@alexaegis/common#build-lib_",
				"@alexaegis/fs#build-lib_",
				"@alexaegis/workspace-tools#build-lib_",
				"@pakk/core#build-lib_"
			],
			"inputs": [
				"{src,static,public}/**/*",
				"*.*",
				"!{src,static,public}/**/*.spec.{ts,js,tsx,jsx}",
				"!vite*.config.*.*"
			],
			"outputs": ["{dist,build,.svelte-kit}/**/*"]
		}
	}
}
